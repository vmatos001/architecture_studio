<div class="relative h-screen w-full overflow-hidden bg-background">
  <!-- 12-Column Blueprint Grid Overlay -->
  <div class="grid-overlay absolute inset-0 pointer-events-none z-10 hidden md:block"></div>
  
  <!-- Poster image (instant LCP) -->
  <img 
    id="heroPoster"
    alt="DISERA Hero Concept Poster" 
    class="absolute inset-0 w-full h-full object-cover z-0 transition-opacity duration-700 opacity-100" 
    src="https://lh3.googleusercontent.com/aida-public/AB6AXuC3wd18DR_01sCb0IXUadfDodb_VfLEG1nEmCTwaYyfGMewq6JVOsJRWa0_7KbUAWNHeF8irWTtucGe1mAtwT2ykUG4cloceEjx_Ctbh3gOf_mcESqBniabKQB9FG-Z7xt89Jd15h1ARCdxGaQo9wm3hw8_jdkH0wxk9uEUEhjAD95eBQhltHIE_Iiyiy0f_nviq3OQ9ii-mEjHn5cqtCI_Yjw1SjdGP_l32b6MpegK218CwaUgeeXZEUapRF8OK3d86DaTMPx_LPU"
  />
  
  <!-- Video Element (Autoplay in loop) -->
  <video 
    id="heroVideo"
    class="absolute inset-0 w-full h-full object-cover z-0 opacity-0 transition-opacity duration-700" 
    autoplay 
    loop 
    muted 
    playsinline 
    preload="none"
  >
    <!-- We will inject the src dynamically via script -->
  </video>

  <!-- Dark overlay to ensure contrast for text and cards -->
  <div class="absolute inset-0 bg-obsidian/45 z-10 pointer-events-none"></div>

  <!-- Content Overlay -->
  <div class="absolute inset-0 z-20 flex flex-col justify-between px-mobile-margin py-mobile-margin md:px-grid-margin md:py-12 pointer-events-none hero-content-overlay select-none">
    
    <!-- Top Spacer to clear the header -->
    <div class="h-24"></div>

    <!-- Middle Section: Side Descriptions (Desktop Only) -->
    <div class="flex-grow relative w-full flex items-start mt-6">
      <!-- Box C: Left Side Description -->
      <div class="absolute top-4 left-0 w-72 text-left hidden md:block animate-fade-in delay-200">
        <p class="font-body-md text-body-md text-travertine/80 leading-relaxed uppercase tracking-widest text-[11px]">
          Diseñamos espacios<br/>que fusionan estética<br/>y funcionalidad.
        </p>
      </div>
      
      <!-- Right Side Description -->
      <div class="absolute top-4 right-0 w-72 text-right hidden md:block animate-fade-in delay-300">
        <p class="font-body-md text-body-md text-travertine/80 leading-relaxed uppercase tracking-widest text-[11px]">
          Diseñando la vida<br/>del futuro.
        </p>
      </div>
    </div>

    <!-- Box B: Giant Brand Text (DISERA) -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-20 pointer-events-none select-none w-full animate-title flex justify-center">
      <h1 class="giant-title uppercase tracking-widest text-center leading-none">
        DISERA
      </h1>
    </div>

    <!-- Bottom Section: Consultation CTA & Floating Cards -->
    <div class="flex flex-col md:flex-row md:items-end justify-between w-full gap-8 z-20 mt-auto">
      
      <!-- Box D: Bottom Left Button (Consultation CTA - styled like Iniciar conversación) -->
      <div class="flex justify-start md:w-1/2 pointer-events-auto animate-slide-up delay-500">
        <a href="/contacto" class="hero-cta-btn inline-block px-12 py-5 border border-travertine bg-transparent text-travertine font-label-sm text-label-sm uppercase tracking-[0.2em] hover:bg-travertine hover:text-obsidian transition-all duration-700">
          Consulta Gratuita
        </a>
      </div>

      <!-- Box A: Bottom Right Cards -->
      <div class="flex flex-col gap-4 md:w-1/2 md:items-end animate-slide-up delay-600">
        <!-- Card 1 -->
        <div class="floating-card flex flex-col justify-center px-6 py-5 bg-obsidian/60 border border-white/10 backdrop-blur-md w-72 text-left pointer-events-auto">
          <span class="font-display-lg text-display-lg-mobile text-white leading-none font-bold">15+</span>
          <span class="font-body-md text-technical-data text-travertine/60 mt-2 leading-relaxed">Años de excelencia e innovación arquitectónica</span>
        </div>
        
        <!-- Card 2 -->
        <div class="floating-card flex flex-col justify-center px-6 py-5 bg-obsidian/60 border border-white/10 backdrop-blur-md w-72 text-left pointer-events-auto relative overflow-hidden">
          <div class="flex items-center justify-between">
            <span class="font-display-lg text-display-lg-mobile text-white leading-none font-bold">549</span>
            <!-- Sparkle Icon -->
            <svg class="w-7 h-7 text-brushed-bronze animate-pulse fill-current" viewBox="0 0 24 24">
              <path d="M12 0L14.6 9.4L24 12L14.6 14.6L12 24L9.4 14.6L0 12L9.4 9.4L12 0Z"/>
            </svg>
          </div>
          <span class="font-body-md text-technical-data text-travertine/60 mt-2 leading-relaxed">Proyectos completados a nivel mundial con éxito</span>
          <!-- Secondary tiny sparkle in corner -->
          <svg class="absolute bottom-2 right-2 w-3.5 h-3.5 text-brushed-bronze/40 fill-current" viewBox="0 0 24 24">
            <path d="M12 0L14.6 9.4L24 12L14.6 14.6L12 24L9.4 14.6L0 12L9.4 9.4L12 0Z"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @font-face {
    font-family: 'Le Jour Serif';
    font-style: normal;
    font-weight: normal;
    font-display: swap;
    src: url('https://font-public.canva.com/YAEl5FtA9yE/0/Le_Jour_Serif.7498b939ba9bf5618bdc813cc1.f01882ac7915c5c139e4080e85fafc13.woff2') format('woff2');
  }

  /* 12-Column blueprint grid overlay */
  .grid-overlay {
    background-image: 
      linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: calc(100% / 12) 100%;
  }

  /* Giant metallic outline title styling */
  .giant-title {
    font-family: 'Le Jour Serif', serif;
    font-size: clamp(3rem, 11.5vw, 11.5rem);
    font-weight: normal;
    color: transparent; /* Pure outline, video filters through completely */
    -webkit-text-stroke: 1px #EAE6DF; /* Solid 1px stroke matching the CTA button border color (#EAE6DF) */
    filter: drop-shadow(0px 8px 24px rgba(0,0,0,0.5));
    
    /* Enable all OpenType ligatures and alternates */
    font-variant-ligatures: common-ligatures discretionary-ligatures contextual;
    font-feature-settings: "liga" on, "clig" on, "calt" on, "dlig" on, "ss01" on, "ss02" on, "ss03" on, "ss04" on, "ss05" on;
    letter-spacing: normal;
  }


  /* Floating cards */
  .floating-card {
    border-radius: 0px; /* Sharp corners */
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.5);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .floating-card:hover {
    transform: translateY(-5px) scale(1.02);
    box-shadow: 0 20px 45px rgba(0, 0, 0, 0.65);
    border-color: rgba(255, 255, 255, 0.25);
  }

  /* Staggered entrance animations */
  .animate-title,
  .animate-fade-in,
  .animate-slide-up {
    opacity: 0;
    transition: opacity 3.6s cubic-bezier(0.16, 1, 0.3, 1), transform 3.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Active state triggers */
  .hero-content-overlay.active .animate-title {
    opacity: 1;
    transform: translateX(-50%) scale(1) translateY(0);
    transition-delay: 450ms;
  }
  .hero-content-overlay .animate-title {
    transform: translateX(-50%) scale(0.95) translateY(40px); /* Appear from bottom to top */
    transition: opacity 3.6s cubic-bezier(0.16, 1, 0.3, 1), transform 3.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .hero-content-overlay.active .animate-fade-in {
    opacity: 1;
    transform: translateY(0);
  }
  .hero-content-overlay .animate-fade-in {
    transform: translateY(-10px);
  }
  .hero-content-overlay.active .delay-200 { transition-delay: 1200ms; }
  .hero-content-overlay.active .delay-300 { transition-delay: 1800ms; }

  .hero-content-overlay.active .animate-slide-up {
    opacity: 1;
    transform: translateY(0);
  }
  .hero-content-overlay .animate-slide-up {
    transform: translateY(25px);
  }
  .hero-content-overlay.active .delay-400 { transition-delay: 2400ms; }
  .hero-content-overlay.active .delay-500 { transition-delay: 3000ms; }
  .hero-content-overlay.active .delay-600 { transition-delay: 3600ms; }

  /* Hero Button Styling Override */
  .hero-cta-btn {
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }
  .hero-cta-btn:hover {
    box-shadow: 0 10px 25px rgba(255,255,255,0.15);
  }
</style>

<script>
  // Lazy load video source and autoplay
  const video = document.getElementById('heroVideo') as HTMLVideoElement;
  const poster = document.getElementById('heroPoster') as HTMLImageElement;
  
  const videoSrc = "https://res.cloudinary.com/dyn04hssj/video/upload/f_auto,q_auto/cinematic_architectural_transformation_2026_pbbzps.webm";

  const lazyLoadVideo = () => {
    if (!video) return;

    // Set source
    video.src = videoSrc;
    video.load();

    // Fade-in when ready to play
    video.addEventListener('canplay', () => {
      video.classList.remove('opacity-0');
      video.classList.add('opacity-100');
      if (poster) {
        poster.classList.remove('opacity-100');
        poster.classList.add('opacity-0');
      }
      
      video.play().catch(err => {
        console.log("Autoplay failed or was blocked by browser:", err);
      });
    }, { once: true });
  };

  const triggerOverlayEntrance = () => {
    const overlay = document.querySelector('.hero-content-overlay');
    if (overlay) {
      overlay.classList.add('active');
    }
  };

  // Run on DOM loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      lazyLoadVideo();
      triggerOverlayEntrance();
    });
  } else {
    lazyLoadVideo();
    triggerOverlayEntrance();
  }
</script>
