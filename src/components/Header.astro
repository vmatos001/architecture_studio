---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.replace(/\/$/, "") || "/";

const links = [
  { name: "Inicio", href: "/" },
  { name: "Proyectos", href: "/proyectos" },
  { name: "Estudio", href: "/estudio" },
  { name: "Journal", href: "/journal" },
  { name: "Contacto", href: "/contacto" }
];
---

<header id="mainHeader" class="fixed top-0 left-0 w-full z-[60] h-24 flex items-center px-mobile-margin md:px-grid-margin transition-all duration-500">
  <div class="flex justify-between items-center w-full max-w-[1920px] mx-auto">
    <!-- Brand Logo -->
    <a class="logo font-display-lg text-headline-md tracking-[0.2em] transition-colors duration-500" href="/">DISERA</a>
    
    <!-- Navigation Links -->
    <nav class="hidden md:flex items-center gap-3">
      {links.map(link => {
        const isActive = currentPath === link.href;
        return (
          <a 
            class={`nav-link font-label-sm text-label-sm ${isActive ? "active" : ""}`} 
            href={link.href}
          >
            {link.name}
          </a>
        );
      })}
    </nav>
    
    <!-- Right Actions (Socials & Action Button) -->
    <div class="hidden md:flex items-center gap-6">
      <!-- Socials -->
      <div class="flex items-center gap-2">
        <a href="https://facebook.com" target="_blank" class="social-link flex items-center justify-center w-10 h-10 border text-technical-data transition-all duration-500" aria-label="Facebook">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
        </a>
        <a href="https://instagram.com" target="_blank" class="social-link flex items-center justify-center w-10 h-10 border text-technical-data transition-all duration-500" aria-label="Instagram">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href="https://x.com" target="_blank" class="social-link flex items-center justify-center w-10 h-10 border text-technical-data transition-all duration-500" aria-label="X (Twitter)">
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
      
      <!-- Consultation Button (Aspect of "Iniciar conversación" / Rectangular border) -->
      <a href="/contacto" class="consult-btn flex items-center gap-3 px-8 py-3 border text-label-sm font-label-sm uppercase tracking-[0.2em] transition-all duration-700 group">
        <span>Consulta</span>
        <span class="material-symbols-outlined text-sm relative transition-transform group-hover:translate-x-1">arrow_right_alt</span>
      </a>
    </div>
    
    <!-- Mobile Menu Button -->
    <button class="menu-btn md:hidden" id="mobileMenuBtn" aria-label="Abrir menú">
      <span class="material-symbols-outlined text-3xl">menu</span>
    </button>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div class="fixed inset-0 bg-background/95 backdrop-blur-2xl z-[70] flex flex-col justify-center px-mobile-margin transition-all duration-700 ease-in-out opacity-0 pointer-events-none translate-y-4" id="mobileMenu">
  <div class="absolute top-0 left-0 w-full h-24 flex items-center justify-between px-mobile-margin border-b border-obsidian/10">
    <a class="font-display-lg text-headline-md tracking-[0.2em] text-primary" href="/">DISERA</a>
    <button class="text-primary" id="closeMenuBtn" aria-label="Cerrar menú">
      <span class="material-symbols-outlined text-3xl">close</span>
    </button>
  </div>
  
  <nav class="flex flex-col gap-6 text-left mt-24">
    {links.map(link => {
      const isActive = currentPath === link.href;
      return (
        <a 
          class={`font-display-lg text-display-lg-mobile tracking-[0.1em] transition-all duration-500 ${
            isActive 
              ? "text-brushed-bronze" 
              : "text-primary hover:text-brushed-bronze"
          }`} 
          href={link.href}
        >
          {link.name}
        </a>
      );
    })}
  </nav>
  
  <div class="mt-auto mb-12 border-t border-obsidian/10 pt-8 flex justify-between">
    <span class="font-technical-data text-technical-data text-on-surface-variant">© 2024 DISERA</span>
    <span class="font-technical-data text-technical-data text-primary">Madrid / Paris / Tokyo</span>
  </div>
</div>

<style>
  header {
    background-color: transparent;
    border-bottom: 1px solid transparent;
    color: #ffffff;
  }
  header.scrolled {
    background-color: rgba(253, 249, 242, 0.95); /* Disera Background */
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(18, 18, 18, 0.1);
    color: #121212;
  }
  
  /* Brand Logo */
  .logo {
    color: #ffffff;
  }
  header.scrolled .logo {
    color: #121212;
  }
  
  /* Navigation Link Pills - Replaced with sharp square style */
  .nav-link {
    padding: 0.5rem 1.25rem;
    border-radius: 0px; /* Sharp corners */
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #ffffff;
    background-color: transparent;
    transition: all 0.5s ease;
  }
  .nav-link:hover {
    border-color: #ffffff;
  }
  .nav-link.active {
    background-color: #ffffff;
    border-color: #ffffff;
    color: #000000;
  }
  
  /* Scrolled Navigation Link Pills */
  header.scrolled .nav-link {
    border-color: rgba(18, 18, 18, 0.2);
    color: #121212;
  }
  header.scrolled .nav-link:hover {
    border-color: #121212;
  }
  header.scrolled .nav-link.active {
    background-color: #121212;
    border-color: #121212;
    color: #ffffff;
  }
  
  /* Social Links - Replaced with sharp square style */
  .social-link {
    border-radius: 0px; /* Sharp corners */
    border-color: rgba(255, 255, 255, 0.25);
    color: #ffffff;
  }
  .social-link:hover {
    border-color: #ffffff;
  }
  header.scrolled .social-link {
    border-color: rgba(18, 18, 18, 0.2);
    color: #121212;
  }
  header.scrolled .social-link:hover {
    border-color: #121212;
  }
  
  /* Consultation Button - Replaced with Iniciar conversación rectangular style */
  .consult-btn {
    border-radius: 0px; /* Sharp corners */
    background-color: transparent;
    border-color: rgba(255, 255, 255, 0.3);
    color: #ffffff;
  }
  .consult-btn:hover {
    background-color: #ffffff;
    border-color: #ffffff;
    color: #000000;
  }
  
  /* Scrolled Consultation Button */
  header.scrolled .consult-btn {
    background-color: transparent;
    border-color: rgba(18, 18, 18, 0.2);
    color: #121212;
  }
  header.scrolled .consult-btn:hover {
    background-color: #121212;
    border-color: #121212;
    color: #ffffff;
  }
  
  /* Mobile Menu Button */
  .menu-btn {
    color: #ffffff;
    transition: color 0.5s ease;
  }
  header.scrolled .menu-btn {
    color: #121212;
  }
</style>

<script>
  // Mobile menu handlers
  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const closeMenuBtn = document.getElementById('closeMenuBtn');
  const mobileMenu = document.getElementById('mobileMenu');

  if (mobileMenuBtn && closeMenuBtn && mobileMenu) {
    mobileMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
      mobileMenu.classList.add('opacity-100', 'translate-y-0');
      document.body.style.overflow = 'hidden';
    });

    closeMenuBtn.addEventListener('click', () => {
      mobileMenu.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
      mobileMenu.classList.remove('opacity-100', 'translate-y-0');
      document.body.style.overflow = '';
    });
  }

  // Header scroll class toggle
  const header = document.getElementById('mainHeader');
  const handleScroll = () => {
    if (!header) return;
    if (window.scrollY > 50) {
      header.classList.add('scrolled');
    } else {
      header.classList.remove('scrolled');
    }
  };
  
  window.addEventListener('scroll', handleScroll);
  // Initial check
  handleScroll();
</script>
