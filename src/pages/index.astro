---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroVideo from '../components/HeroVideo.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="DISERA | Estudio de Arquitectura">
  <Header />
  
  <main class="relative z-10">
    <!-- Scroll container with video hero -->
    <HeroVideo />
    
    <!-- Manifiesto Section -->
    <section class="py-section-padding px-mobile-margin md:px-grid-margin max-w-[1920px] mx-auto fade-in-section bg-background border-t border-obsidian/10">
      <div class="grid grid-cols-12 gap-grid-gutter">
        <div class="col-span-12 md:col-start-3 md:col-span-8 text-center">
          <span class="font-label-sm text-label-sm text-brushed-bronze block mb-12 tracking-widest">MANIFESTO</span>
          <h2 class="font-display-lg text-headline-md md:text-display-lg-mobile leading-tight mb-12 text-primary uppercase">
            La forma sigue a la luz.<br/>No añadimos. Revelamos.
          </h2>
          <div class="w-24 h-hairline bg-brushed-bronze mx-auto mb-12"></div>
          <p class="font-body-lg text-body-lg text-on-surface-variant max-w-3xl mx-auto leading-relaxed">
            En DISERA concebimos la arquitectura como una disciplina de contención. Diseñamos volúmenes honestos, donde la materia y el vacío dialogan en silencio. Cada línea es una decisión. Cada plano, una búsqueda de permanencia.
          </p>
        </div>
      </div>
    </section>

    <!-- Obras Seleccionadas (Bento Grid Architectural) -->
    <section class="py-section-padding bg-surface-container-low relative">
      <div class="px-mobile-margin md:px-grid-margin max-w-[1920px] mx-auto mb-16 flex justify-between items-end">
        <div>
          <h3 class="font-display-lg text-headline-md text-primary mb-2">Obras Seleccionadas</h3>
          <p class="font-label-sm text-label-sm text-on-surface-variant tracking-widest">PORTAFOLIO 2020 — 2024</p>
        </div>
        <a class="hidden md:flex items-center gap-2 font-label-sm text-label-sm text-primary group" href="/proyectos">
          Ver todos los proyectos 
          <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_right_alt</span>
        </a>
      </div>
      
      <div class="px-mobile-margin md:px-grid-margin max-w-[1920px] mx-auto grid grid-cols-1 md:grid-cols-12 gap-hairline bg-obsidian/10">
        <!-- Project 1 -->
        <div class="md:col-span-8 bg-background group overflow-hidden relative fade-in-section">
          <div class="aspect-[16/9] overflow-hidden">
            <img 
              class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105" 
              alt="Casa Acantilado" 
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuDZ9uOUxOtEx-igdTHmjefJfXbCzwkE19j7MGSzKYmV07WCII_rA7d7Us_ET0c2uAsaKKSGAzAS0X1tm1olokv97rQLrQ5zH_yfJwT5XI5F10iw3MzU6Lx-ggj8yxAoMPH_qqubw58exRczbbPxnmuB8xzQkFbv8GCQZJpZtPe0OYkf53zAI4Frb3FfgKCZt2V-0I2YJWOZftP8fB3GZ_4yhgdT8EZbLRmM2xnEO3pUjWRkpNN6c6LicO0zqYHRb33sjJNRY2OFqos"
            />
          </div>
          <div class="absolute bottom-0 left-0 p-8 w-full bg-gradient-to-t from-obsidian/80 to-transparent translate-y-full group-hover:translate-y-0 transition-transform duration-700">
            <div class="flex justify-between items-end">
              <div>
                <p class="font-technical-data text-technical-data text-travertine mb-2">01. RESIDENCIAL</p>
                <h4 class="font-headline-md text-travertine">Casa Acantilado</h4>
              </div>
              <span class="font-technical-data text-technical-data text-travertine">Costa Brava, ES</span>
            </div>
          </div>
        </div>
        
        <!-- Project 2 -->
        <div class="md:col-span-4 bg-background group overflow-hidden relative fade-in-section">
          <div class="aspect-[4/5] md:aspect-auto h-full overflow-hidden">
            <img 
              class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105" 
              alt="Pabellón de Piedra" 
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuDgg4CZ7gyOa_nXSx-gkcDPdCbr2zLLrmKV8GSGC0puJ6wJiRm7gn6AQ1-rc_OlthmW2Rzlb3POR9sMnh5iGIM8blNbA9WbORKberG-LNn35b_om-ex27w6ZQSJA5XpR4GOuZghJr6AHFH4IO5B-jSYs669VK9hr9rB77jpa-MtypbGj3Q6TTGSMENRXnEv6gb7hhcg8OSyNcjU_nujMHbrTsPcOJtaotR9gs9PKEvrGiTIwSP-c5Jt7ErfF_D-enmNBw3J9dKvNU4"
            />
          </div>
          <div class="absolute inset-0 p-8 flex flex-col justify-end bg-gradient-to-t from-obsidian/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700">
            <p class="font-technical-data text-technical-data text-travertine mb-2">02. ESTUDIO</p>
            <h4 class="font-headline-md text-travertine">Pabellón de Piedra</h4>
          </div>
        </div>
        
        <!-- Project 3 -->
        <div class="md:col-span-4 bg-background group overflow-hidden relative fade-in-section">
          <div class="aspect-[4/5] md:aspect-auto h-full overflow-hidden">
            <img 
              class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105" 
              alt="Ático Retiro" 
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuA_-VGbwmnDUj7iqGVt9hTnuFyYb2C6jV9CNsZTbdjdmTN8yMicT_F4P_HPJ9RKs41aNEByBmQwG0B9auiYQaiGMhgQDE5NJRL1mc0Qtx9hym3MVAMQVSzj2Itl-ARgxOktMrEpgEp9eWWpqnPpEesHiZq99CZ6ZFDhRyiVplZq-qpb2Vin6BkI8tZTStXo80XO1XMljHy_hUq-f_CKBEqqFbPlx97YLoC_kgLqX0RHJy6aQIvA3iZeyuTGfyN65gnQYNGIqG-BSjc"
            />
          </div>
          <div class="absolute inset-0 p-8 flex flex-col justify-end bg-gradient-to-t from-obsidian/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700">
            <p class="font-technical-data text-technical-data text-travertine mb-2">03. INTERIORISMO</p>
            <h4 class="font-headline-md text-travertine">Ático Retiro</h4>
          </div>
        </div>
        
        <!-- Project 4 -->
        <div class="md:col-span-8 bg-background group overflow-hidden relative fade-in-section">
          <div class="aspect-[16/9] overflow-hidden">
            <img 
              class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105" 
              alt="Centro Cultural Luz" 
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuAoQmIDbIYPX8iQ0IVzlY3GWnzr-_UaAstf-31Rlv21Bs7w5u68Nqx1hsUMpxOOACoAOh6YDV7VCB8dNl4dxU_HzEJo30i3f5aMrt45OL72pZiv7Q5HytGroT9d_hArb7TOd316d6R2oyFEPhxaAYYo1IfRfElSthATfWj__ecSblAWBA5YY0LVUJWg3NQudj8fC35_PwZ4OnmekI57ya_FyUXMB-yRSekAgRMaSSB8lAQyBTma8-ApjIxirzo7hH8MKUjQ47G0A-Q"
            />
          </div>
          <div class="absolute bottom-0 left-0 p-8 w-full bg-gradient-to-t from-obsidian/80 to-transparent translate-y-full group-hover:translate-y-0 transition-transform duration-700">
            <div class="flex justify-between items-end">
              <div>
                <p class="font-technical-data text-technical-data text-travertine mb-2">04. PÚBLICO</p>
                <h4 class="font-headline-md text-travertine">Centro Cultural Luz</h4>
              </div>
              <span class="font-technical-data text-technical-data text-travertine">Madrid, ES</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Project Data / Technical Table -->
    <section class="py-section-padding px-mobile-margin md:px-grid-margin max-w-[1920px] mx-auto fade-in-section">
      <div class="grid grid-cols-12 gap-grid-gutter">
        <div class="col-span-12 md:col-span-4 mb-12 md:mb-0">
          <h3 class="font-headline-md text-headline-md text-primary mb-6">Rigurosidad Técnica</h3>
          <p class="font-body-md text-body-md text-on-surface-variant">Cada proyecto es un ejercicio de precisión técnica. Documentamos el proceso desde la concepción hasta el último detalle constructivo.</p>
        </div>
        
        <div class="col-span-12 md:col-start-6 md:col-span-7">
          <div class="space-y-0 border-t border-obsidian/10">
            <div class="flex justify-between py-6 border-b border-obsidian/10 group hover:bg-surface-container-low transition-colors px-4">
              <span class="font-label-sm text-label-sm text-on-surface-variant">Superficie Total</span>
              <span class="font-technical-data text-technical-data text-primary">12.450 m² Desarrollados</span>
            </div>
            <div class="flex justify-between py-6 border-b border-obsidian/10 group hover:bg-surface-container-low transition-colors px-4">
              <span class="font-label-sm text-label-sm text-on-surface-variant">Materiales Predominantes</span>
              <span class="font-technical-data text-technical-data text-primary">Travertino, Bronce Cepillado, Roble</span>
            </div>
            <div class="flex justify-between py-6 border-b border-obsidian/10 group hover:bg-surface-container-low transition-colors px-4">
              <span class="font-label-sm text-label-sm text-on-surface-variant">Certificaciones</span>
              <span class="font-technical-data text-technical-data text-primary">Passivhaus, LEED Platinum</span>
            </div>
            <div class="flex justify-between py-6 border-b border-obsidian/10 group hover:bg-surface-container-low transition-colors px-4">
              <span class="font-label-sm text-label-sm text-on-surface-variant">Reconocimientos</span>
              <span class="font-technical-data text-technical-data text-primary">Mies van der Rohe Nominee</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Call to Action -->
    <section class="py-section-padding bg-obsidian text-travertine text-center fade-in-section">
      <div class="max-w-2xl mx-auto px-mobile-margin md:px-grid-margin">
        <h2 class="font-display-lg text-headline-md mb-8">¿Hablamos de su próximo espacio?</h2>
        <p class="font-body-md text-body-md text-travertine/60 mb-12">Invitamos a clientes que valoran la atemporalidad y el detalle a contactar con nuestro estudio en Madrid.</p>
        <a class="inline-block px-12 py-4 border border-travertine font-label-sm text-label-sm uppercase tracking-widest hover:bg-travertine hover:text-obsidian transition-all duration-700" href="/contacto">
          Iniciar Conversación
        </a>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
